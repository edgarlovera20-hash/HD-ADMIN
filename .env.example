# HD-ADMIN Environment Template
# Copy to .env and fill in real values. Never commit .env to version control.

NODE_ENV=development
APP_NAME=HD-ADMIN
APP_PORT=3004
API_BASE_URL=http://localhost:3004

# HD-CORE dependency resolution (local | registry)
HD_CORE_MODE=local

# Databases
DATABASE_URL=postgresql://user:password@localhost:5432/hdadmin
AUDIT_DB_URL=postgresql://user:password@localhost:5432/hdaudit
FINANCE_DB_URL=postgresql://user:password@localhost:5432/hdfinance

# Event Bus
EVENT_BUS_URL=amqp://localhost:5672

# Authentication
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=1h

# n8n Automation
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=dev-n8n-secret

# Cross-platform event forwarding (producers send to subscriber ingest endpoints)
EVENT_BUS_SECRET=replace-with-a-strong-secret
BRAIN_EVENTS_URL=http://localhost:3003/api/events/ingest

# Logging
LOG_LEVEL=info
